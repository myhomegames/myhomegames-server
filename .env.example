# Development configuration
# API_TOKEN for development authentication (development only)
API_TOKEN=changeme

# Server port (optional, defaults to 4000)
PORT=4000

# HTTP server port (optional, defaults to PORT or 4000)
# HTTP_PORT=4000

# HTTPS server configuration (development only - optional)
# In production, HTTPS is handled by your hosting provider/reverse proxy
# HTTPS_ENABLED=false
# HTTPS_PORT=41440

# Frontend URL (optional - only needed if Origin header is not available)
# Normally not needed in development as the browser always sends the Origin header                                                                              
# Only useful when testing with curl/Postman or if a proxy filters the Origin header                                                                            
# FRONTEND_URL=https://localhost:5173/app/
# COVER_TAG_URL=http://localhost:5173

# Metadata path (optional). Defaults:
#   macOS: ~/Library/Application Support/MyHomeGames
#   Windows: %APPDATA%\MyHomeGames
#   Linux: $XDG_DATA_HOME/MyHomeGames or ~/.local/share/MyHomeGames
# METADATA_PATH=/path/to/your/metadata
#
# Default Plex skin on first startup when METADATA_PATH/skins is empty.
# By default: plex.mhg-skin.zip from the latest GitHub Release of myhomegames-skins.
# MHG_SKINS_GITHUB_REPO=myhomegames/myhomegames-skins
# DEFAULT_SKIN_URL=https://github.com/myhomegames/myhomegames-skins/releases/download/1.1.0/plex.mhg-skin.zip

# API_BASE=http://localhost:4000

# Cloudflare Tunnel (optional) — per-user tunnel via Cloudflare Access + tunnel manager worker.
# Enable on the server; the web app fetches a run token after Access login and POSTs /tunnel/connect.
# The tunnel run token is stored under METADATA_PATH/tokens/cloudflare-tunnel-run.json (not in .env).
# CLOUDFLARE_TUNNEL_ENABLED=true
# API_BASE=https://your-user-myhomegames-server.vige.it
# HTTPS_ENABLED=false
# Tunnel manager URL (web: VITE_TUNNEL_MANAGER_URL), e.g. https://myhomegames-server.vige.it
# Advanced local dev only — ~/.cloudflared/config.yml or generated credentials:
# CLOUDFLARE_TUNNEL_CONFIG=/Users/you/.cloudflared/config.yml
# Or credentials + tunnel id (generates config under METADATA_PATH/cloudflared/):
# CLOUDFLARE_TUNNEL_ID=
# CLOUDFLARE_TUNNEL_CREDENTIALS_FILE=/Users/you/.cloudflared/<tunnel-id>.json
# CLOUDFLARE_TUNNEL_HOSTNAME=myhomegames-server.vige.it
# CLOUDFLARE_TUNNEL_VERBOSE=true
# CLOUDFLARE_TUNNEL_STRICT=true

# Optional: GitHub Personal Access Token (classic) with "repo" scope for npm run release.
# Without it, release-it opens the GitHub web UI (no automatic asset upload).
# Create at https://github.com/settings/tokens
# GITHUB_TOKEN=ghp_your_token_here

# Package publishing (optional — used by scripts/publish-package-repos.js)
# PACKAGE_REPO_SSH=deploy@packages.myhomegames.vige.it
# PACKAGE_REPO_APT_ROOT=/var/www/packages/apt
# PACKAGE_REPO_YUM_ROOT=/var/www/packages/yum/el9/x86_64
# PACKAGE_REPO_APT_CODENAME=stable
# HOMEBREW_TAP_REPO=git@github.com:myhomegames/homebrew-tap.git
