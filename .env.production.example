# Production configuration
# DO NOT use API_TOKEN in production - use Twitch OAuth instead

# Server port
PORT=4000

# Frontend URL (optional - only needed if Origin header is not available)
# Normally not needed as the browser always sends the Origin header
# Only useful if a proxy/CDN filters or modifies the Origin header
# FRONTEND_URL=https://your-frontend-domain.com
# COVER_TAG_URL=https://your-frontend-domain.com

# Metadata path (required in production)
METADATA_PATH=/path/to/your/metadata
# Optional: default skin archive installed+selected on first startup if skins/ is empty
# DEFAULT_SKIN_URL=https://myhomegamesskins.vige.it/zips/plex.mhg-skin.zip

API_BASE=https://your-api-domain.com
